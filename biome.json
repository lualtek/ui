{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "extends": ["@lualtek/biome-config/core"],
  "formatter": {
    "includes": ["**", "!**/*.{js,ts,tsx,mjs,cjs}"]
  },
  "linter": {
    "includes": ["**", "!**/types/**", "!**/*.{js,ts,tsx,mjs,cjs}", "!*.{js,ts,tsx,mjs,cjs}"],
    "rules": {
      "correctness": {
        "noUnknownFunction": "error",
        "noUnknownMediaFeatureName": "off"
      },
      "suspicious": {
        "noUnknownAtRules": {
          "level": "error",
          "options": {
            "ignore": ["custom-selector"]
          }
        }
      }
    }
  },
  "javascript": {
    "linter": {
      "enabled": false
    },
    "formatter": {
      "enabled": false
    },
    "globals": ["React"]
  }
}
