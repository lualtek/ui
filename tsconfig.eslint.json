{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "ESlint",
  "extends": "./packages/tsconfig/base.json",
  "exclude": ["node_modules"],
  "include": [
    "**/.eslintrc.cjs",
    "**/.storybook/*.js",
    "**/.storybook/*.ts",
    "**/*.mjs",
    "**/*.cjs",
    "**/*.js",
    "**/*.ts",
    "**/*.tsx"
  ]
}
