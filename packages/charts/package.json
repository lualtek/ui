{
  "name": "@lualtek/charts",
  "version": "18.4.0",
  "files": [
    "dist"
  ],
  "type": "module",
  "types": "dist/index.d.ts",
  "module": "dist/index.js",
  "main": "dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./doc/*": "./dist/components/*/*.doc.json",
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "scripts": {
    "dev": "pnpm run --parallel watch:csstypes",
    "prebuild": "pnpm run clean && pnpm run build:csstypes",
    "build": "pnpm run build:ts && pnpm run build:css && pnpm run build:api",
    "build:css": "cd src && copyfiles \"**/*.css\" \"./../dist\"",
    "build:ts": "tsc -p tsconfig.prod.json && tsc-alias",
    "build:api": "typedoc && typedoc-json-parser --json dist/api-temp.json && tsx ./generate-api-doc.ts",
    "postbuild:api": "rimraf dist/api-temp.json",
    "watch:csstypes": "tcm -w -p '**/*.module.css' src",
    "build:csstypes": "tcm -p '**/*.module.css' src",
    "clean": "rimraf dist",
    "prepack": "tsx ./prepack.ts"
  },
  "repository": {
    "type": "git",
    "url": "ssh+https://github.com/lualtek/ui.git",
    "directory": "packages/charts"
  },
  "bugs": {
    "url": "https://github.com/lualtek/ui/issues"
  },
  "homepage": "https://github.com/lualtek/ui",
  "browserslist": [
    "last 2 Chrome versions",
    "last 2 Firefox versions",
    "last 2 Safari versions",
    "last 2 Edge versions",
    "not dead",
    "not op_mini all"
  ],
  "peerDependencies": {
    "react": "^18.2",
    "react-dom": "^18.2"
  },
  "devDependencies": {
    "@types/node": "22.13.2",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "react": "^18.3",
    "react-dom": "^18.3",
    "tsconfig": "workspace:*",
    "typed-css-modules": "0.9.1",
    "typedoc": "0.27.7",
    "typedoc-json-parser": "10.2.0",
    "typescript": "5.7.3"
  },
  "dependencies": {
    "@lualtek/react-components": "workspace:*",
    "@lualtek/tokens": "workspace:*",
    "clsx": "2.1.1",
    "recharts": "2.13.3",
    "type-fest": "4.34.1"
  }
}
