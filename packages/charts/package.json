{
  "name": "@lualtek/charts",
  "version": "2026.2.5",
  "homepage": "https://github.com/lualtek/ui",
  "bugs": {
    "url": "https://github.com/lualtek/ui/issues"
  },
  "repository": {
    "type": "git",
    "url": "ssh+https://github.com/lualtek/ui.git",
    "directory": "packages/charts"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./doc/*": "./dist/components/*/*.doc.json",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "restricted",
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "dev": "pnpm run --parallel watch:csstypes",
    "prebuild": "pnpm run clean && pnpm run build:csstypes",
    "build": "pnpm run build:ts && pnpm run build:css",
    "build:css": "cd src && copyfiles \"**/*.css\" \"./../dist\"",
    "build:ts": "tsc -p tsconfig.prod.json && tsc-alias",
    "watch:csstypes": "tcm -w -p '**/*.module.css' src",
    "build:csstypes": "tcm -p '**/*.module.css' src",
    "clean": "rimraf dist",
    "prepack": "tsx ./prepack.ts"
  },
  "dependencies": {
    "@lualtek/react-components": "workspace:*",
    "@lualtek/tokens": "workspace:*",
    "clsx": "2.1.1",
    "recharts": "3.7.0",
    "type-fest": "5.4.4"
  },
  "devDependencies": {
    "@types/node": "25.3.3",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "react": "^19.2",
    "react-dom": "^19.2",
    "tsconfig": "workspace:*",
    "typed-css-modules": "0.9.1",
    "typescript": "5.9.3"
  },
  "peerDependencies": {
    "react": "^19.1",
    "react-dom": "^19.1"
  },
  "browserslist": [
    "last 2 Chrome versions",
    "last 2 Firefox versions",
    "last 2 Safari versions",
    "last 2 Edge versions",
    "not dead",
    "not op_mini all"
  ]
}
