{
  "name": "@lualtek/themes",
  "description": "Lualtek design system themes",
  "version": "11.0.0-next.4",
  "author": "Lualtek",
  "main": "platforms/web/themes.css",
  "style": "platforms/web/themes.css",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "files": [
    "platforms/"
  ],
  "exports": {
    "./web/default": "./platforms/web/default/themes.css",
    "./web/default/*.css": "./platforms/web/default/*.css",
    "./web/default/*.json": "./platforms/web/default/*.json",
    "./web/monochrome": "./platforms/web/monochrome/themes.css",
    "./web/monochrome/*.css": "./platforms/web/monochrome/*.css",
    "./web/monochrome/*.json": "./platforms/web/monochrome/*.json"
  },
  "scripts": {
    "prebuild": "rimraf platforms/",
    "build": "run-s build:themes build:combine",
    "build:combine": "ts-node src/combine",
    "build:themes": "ts-node src/index"
  },
  "repository": {
    "type": "git",
    "url": "ssh+https://github.com/lualtek/ui.git",
    "directory": "packages/themes"
  },
  "homepage": "https://github.com/lualtek/ui",
  "bugs": {
    "url": "https://github.com/lualtek/ui/issues"
  },
  "devDependencies": {
    "@lualtek/tokens": "11.0.0-next.4",
    "colorjs.io": "0.4.5",
    "fs-extra": "11.1.1",
    "style-dictionary": "3.9.0",
    "tsconfig": "*",
    "yargs": "17.7.2"
  }
}
