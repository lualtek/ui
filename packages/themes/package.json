{
  "name": "@lualtek/themes",
  "description": "Lualtek design system themes",
  "version": "12.0.0-next.4",
  "author": "Lualtek",
  "style": "platforms/web/themes.css",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "type": "module",
  "files": [
    "platforms/"
  ],
  "exports": {
    "./web": "./platforms/web/default/themes.css",
    "./web/*.css": "./platforms/web/default/*.css",
    "./web/*.json": "./platforms/web/default/*.json",
    "./web/pro": "./platforms/web/pro/themes.css",
    "./web/pro/*.css": "./platforms/web/pro/*.css",
    "./web/pro/*.json": "./platforms/web/pro/*.json"
  },
  "scripts": {
    "prebuild": "rimraf platforms/",
    "build": "pnpm run build:themes && pnpm run build:combine",
    "build:combine": "node --loader ts-node/esm src/combine.ts",
    "build:themes": "node --loader ts-node/esm src/index.ts"
  },
  "repository": {
    "type": "git",
    "url": "ssh+https://github.com/lualtek/ui.git",
    "directory": "packages/themes"
  },
  "homepage": "https://github.com/lualtek/ui",
  "bugs": {
    "url": "https://github.com/lualtek/ui/issues"
  },
  "devDependencies": {
    "@lualtek/tokens": "workspace:*",
    "@types/fs-extra": "11.0.4",
    "@types/node": "20.12.12",
    "colorjs.io": "0.5.0",
    "fs-extra": "11.2.0",
    "style-dictionary": "3.9.2",
    "tsconfig": "workspace:*",
    "yargs": "17.7.2"
  }
}
