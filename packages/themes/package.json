{
  "name": "@lualtek/themes",
  "description": "Lualtek design system themes",
  "version": "20.0.0",
  "author": "Lualtek",
  "style": "platforms/web/themes.css",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "type": "module",
  "files": [
    "platforms/"
  ],
  "exports": {
    "./web": "./platforms/web/default.css",
    "./web/pro": "./platforms/web/pro.css",
    "./web/*.css": "./platforms/web/*.css",
    "./web/*.json": "./platforms/web/*.json"
  },
  "scripts": {
    "prebuild": "rimraf platforms/",
    "build": "pnpm run build:themes",
    "build:themes": "tsx src/index.ts"
  },
  "repository": {
    "type": "git",
    "url": "ssh+https://github.com/lualtek/ui.git",
    "directory": "packages/themes"
  },
  "homepage": "https://github.com/lualtek/ui",
  "bugs": {
    "url": "https://github.com/lualtek/ui/issues"
  },
  "devDependencies": {
    "@types/fs-extra": "11.0.4",
    "@types/node": "24.0.14",
    "colorjs.io": "0.5.2",
    "fs-extra": "11.3.0",
    "style-dictionary": "5.0.1",
    "tsconfig": "workspace:*",
    "yargs": "18.0.0"
  }
}
