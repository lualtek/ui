{
  "name": "@lualtek/themes",
  "description": "Lualtek design system themes",
  "version": "9.3.1",
  "author": "Lualtek",
  "main": "platforms/web/themes.css",
  "style": "platforms/web/themes.css",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "files": [
    "platforms/"
  ],
  "exports": {
    "./web": "./platforms/web/themes.css",
    "./web/dark.css": "./platforms/web/dark.css",
    "./web/light.css": "./platforms/web/light.css",
    "./web/dark.json": "./platforms/web/dark.json",
    "./web/light.json": "./platforms/web/light.json"
  },
  "scripts": {
    "prebuild": "rimraf platforms/",
    "build": "run-s build:light build:dark build:combine",
    "build:combine": "ts-node src/combine",
    "build:light": "ts-node src/index --name light",
    "build:dark": "ts-node src/index --name dark"
  },
  "repository": {
    "type": "git",
    "url": "ssh+https://github.com/lualtek/ui.git",
    "directory": "packages/themes"
  },
  "homepage": "https://github.com/lualtek/ui",
  "bugs": {
    "url": "https://github.com/lualtek/ui/issues"
  },
  "devDependencies": {
    "@lualtek/tokens": "9.3.1",
    "colorjs.io": "0.4.5",
    "fs-extra": "11.1.1",
    "style-dictionary": "3.8.0",
    "tsconfig": "*",
    "yargs": "17.7.2"
  }
}
