{
  "global": {
    "foreground": {
      "$type": "color",
      "value": {
        "light": "{color.primary.60}",
        "dark": "{color.primary.30}"
      }
    },
    "background": {
      "$type": "color",
      "value": {
        "light": "{color.support.white}",
        "dark": "{color.primary.100}"
      }
    },
    "interactive-text": {
      "$type": "color",
      "value": {
        "light": "{color.brand.60}",
        "dark": "{color.brand.40}"
      }
    },
    "interactive-text-hover": {
      "$type": "color",
      "value": {
        "light": "{color.brand.50}",
        "dark": "{color.brand.60}"
      }
    },
    "disabled-foreground": {
      "value": {
        "light": "{color.primary.50}",
        "dark": "{color.primary.5}"
      },
      "transparency": {
        "light": "60%",
        "dark": "20%"
      },
      "$type": "color"
    },
    "disabled-background": {
      "$type": "color",
      "value": {
        "light": "{color.primary.20}",
        "dark": "{color.primary.50}"
      },
      "transparency": {
        "light": "60%",
        "dark": "15%"
      }
    },
    "inner-contrast-border": {
      "$type": "color",
      "value": {
        "light": "{color.support.white}",
        "dark": "{color.support.white}"
      },
      "transparency": {
        "light": "15%",
        "dark": "8%"
      }
    },
    "outer-contrast-border": {
      "$type": "color",
      "value": {
        "light": "{color.primary.80}",
        "dark": "{color.support.black}"
      },
      "transparency": {
        "light": "15%",
        "dark": "40%"
      }
    }
  }
}
