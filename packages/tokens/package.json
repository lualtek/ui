{
  "name": "@lualtek/tokens",
  "version": "19.0.0-next.2",
  "description": "Design tokens from Lualtek design language",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "type": "module",
  "exports": {
    "./web": "./platforms/web/index.js",
    "./web/tokens.json": "./platforms/web/tokens.json",
    "./web/tokens-flat.json": "./platforms/web/tokens-flat.json",
    "./web/tokens.css": "./platforms/web/tokens.css",
    "./raw/tokens.json": "./platforms/raw/tokens.json"
  },
  "typesVersions": {
    "*": {
      "web/*": [
        "platforms/web/*"
      ],
      "raw/*": [
        "platforms/raw/*"
      ],
      "platforms/*": [
        "platforms/*"
      ]
    }
  },
  "files": [
    "platforms/"
  ],
  "scripts": {
    "prebuild": "rimraf platforms/",
    "build": "pnpm run build:tokens && pnpm run build:types",
    "build:tokens": "tsx src/index.ts",
    "build:types": "tsx src/generate-types.ts"
  },
  "repository": {
    "type": "git",
    "url": "ssh+https://github.com/lualtek/ui.git",
    "directory": "packages/tokens"
  },
  "author": "Lualtek",
  "bugs": {
    "url": "https://github.com/lualtek/ui/issues"
  },
  "homepage": "https://github.com/lualtek/ui",
  "devDependencies": {
    "@types/fs-extra": "11.0.4",
    "@types/tinycolor2": "1.4.6",
    "colorjs.io": "0.5.2",
    "fs-extra": "11.3.0",
    "style-dictionary": "4.4.0",
    "tsconfig": "workspace:*"
  }
}
