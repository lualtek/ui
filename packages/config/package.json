    "postcss-preset-env": "10.1.1",
    "postcss-replace": "2.0.1"
  },
  "devDependencies": {
    "@types/flat": "5.0.5",
    "@types/postcss-import": "14.0.3",
    "tsconfig": "workspace:*",
    "typescript": "5.6.3"
  },
  "types": "./dist/index.d.ts"
