{
  "name": "@lualtek/icons",
  "description": "Lualtek's iconography",
  "version": "11.2.0",
  "author": "Lualtek",
  "main": "dist/index",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "exports": {
    "./sprite": "./dist/sprite.svg",
    "./structure": "./dist/structure.json"
  },
  "typesVersions": {
    "*": {
      "sprite": [
        "dist/sprite.d.ts"
      ],
      "structure": [
        "dist/structure.json"
      ]
    }
  },
  "engines": {
    "node": ">=16.x",
    "npm": ">=8.x"
  },
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "run-s build:optimize build:sprite build:clean",
    "build:optimize": "svgo ./svgs/**/* --config=svgo.config.js --quiet",
    "build:sprite": "ts-node ./sprites",
    "build:clean": "rimraf dist/svgs"
  },
  "repository": {
    "type": "git",
    "url": "ssh+https://github.com/lualtek/ui.git",
    "directory": "packages/icons"
  },
  "bugs": {
    "url": "https://github.com/lualtek/ui/issues"
  },
  "homepage": "https://github.com/lualtek/ui#readme",
  "devDependencies": {
    "directory-tree": "3.5.1",
    "fs-extra": "11.1.1",
    "nanospinner": "1.1.0",
    "picocolors": "1.0.0",
    "svgo": "3.0.4",
    "svgstore": "3.0.1",
    "tsconfig": "*"
  }
}
