{
  "name": "@lualtek/icons",
  "description": "Lualtek's iconography",
  "version": "20.6.2",
  "author": "Lualtek",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "type": "module",
  "exports": {
    ".": "./dist/index.js",
    "./sprite": "./dist/sprite.svg",
    "./structure": "./dist/structure.json"
  },
  "typesVersions": {
    "*": {
      "*": [
        "./dist/*"
      ],
      "sprite": [
        "dist/sprite.d.ts"
      ],
      "structure": [
        "dist/structure.json"
      ]
    }
  },
  "engines": {
    "node": ">=18.x",
    "pnpm": ">=8.x"
  },
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "pnpm run build:optimize && pnpm run build:sprite && pnpm run build:clean",
    "build:optimize": "svgo ./svgs/**/* --config=svgo.config.cjs --quiet",
    "build:sprite": "tsx ./sprites.ts",
    "build:clean": "rimraf dist/svgs"
  },
  "repository": {
    "type": "git",
    "url": "ssh+https://github.com/lualtek/ui.git",
    "directory": "packages/icons"
  },
  "bugs": {
    "url": "https://github.com/lualtek/ui/issues"
  },
  "homepage": "https://github.com/lualtek/ui#readme",
  "devDependencies": {
    "@types/fs-extra": "11.0.4",
    "@types/node": "24.5.2",
    "directory-tree": "3.5.2",
    "fs-extra": "11.3.2",
    "nanospinner": "1.2.2",
    "picocolors": "1.1.1",
    "svgo": "4.0.0",
    "svgstore": "3.0.1",
    "tsconfig": "workspace:*"
  }
}
