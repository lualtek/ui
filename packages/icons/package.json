{
  "name": "@lualtek/icons",
  "description": "Lualtek's iconography",
  "version": "0.13.0",
  "author": "Lualtek",
  "main": "dist/index",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "exports": {
    "./sprite": "./dist/sprite.svg",
    "./structure": "./dist/structure.json"
  },
  "typesVersions": {
    "*": {
      "sprite": [
        "dist/sprite.d.ts"
      ],
      "structure": [
        "dist/structure.json"
      ]
    }
  },
  "engines": {
    "node": ">=14.x",
    "npm": ">=8.x"
  },
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "run-s build:copy build:optimize build:sprite build:clean",
    "build:copy": "cpy '**/*.svg' '../dist/svgs' --parents --cwd=svgs",
    "build:optimize": "svgo ./dist/svgs/**/* --config=svgo.config.js --quiet",
    "build:sprite": "ts-node ./sprites",
    "build:clean": "rimraf dist/svgs"
  },
  "repository": {
    "type": "git",
    "url": "ssh+https://github.com/lualtek/ui.git",
    "directory": "packages/icons"
  },
  "bugs": {
    "url": "https://github.com/lualtek/ui/issues"
  },
  "homepage": "https://github.com/lualtek/ui#readme",
  "devDependencies": {
    "directory-tree": "3.3.0",
    "fs-extra": "10.1.0",
    "nanospinner": "0.6.0",
    "picocolors": "1.0.0",
    "svgo": "2.8.0",
    "svgstore": "3.0.1",
    "tsconfig": "*",
    "ts-node": "10.9.1"
  }
}
