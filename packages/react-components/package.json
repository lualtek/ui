{
  "name": "@lualtek/react-components",
  "version": "11.11.0",
  "types": "dist/index.d.ts",
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./core.css": "./dist/core.css",
    "./doc/*": "./dist/components/*/*.doc.json"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "scripts": {
    "dev": "pnpm run --parallel storybook watch:csstypes",
    "prebuild": "pnpm run clean && pnpm run build:csstypes",
    "build": "pnpm run build:ts && pnpm run build:css && pnpm run copy:fonts && pnpm run build:api",
    "build:css": "cpy '**/*.css' '../dist' --parents --cwd=src && postcss dist/*.css \"dist/**/!(utils)/.css\" --replace",
    "copy:fonts": "cpy 'fonts/*' '../dist' --parents --cwd=src",
    "build:ts": "tsc -p tsconfig.prod.json && tsc-alias",
    "build:api": "typedoc && typedoc-json-parser --json dist/api-temp.json && ts-node ./generate-api-doc",
    "postbuild:api": "rimraf dist/api-temp.json",
    "storybook": "storybook dev --quiet -p 6006",
    "build-storybook": "storybook build",
    "watch:csstypes": "tcm -w -p '**/*.module.css' src",
    "build:csstypes": "tcm -p '**/*.module.css' src",
    "clean": "rimraf dist core core.css"
  },
  "repository": {
    "type": "git",
    "url": "ssh+https://github.com/lualtek/ui.git",
    "directory": "packages/react-components"
  },
  "bugs": {
    "url": "https://github.com/lualtek/ui/issues"
  },
  "homepage": "https://github.com/lualtek/ui",
  "browserslist": [
    "last 1 Chrome versions",
    "last 1 Firefox versions",
    "last 1 Safari versions",
    "last 1 Edge versions"
  ],
  "peerDependencies": {
    "constate": "^3.3.2",
    "react": "^18.2",
    "react-dom": "^18.2"
  },
  "devDependencies": {
    "@babel/core": "7.24.0",
    "@babel/preset-env": "7.24.0",
    "@babel/preset-react": "7.23.3",
    "@babel/preset-typescript": "7.23.3",
    "@lualtek/config": "workspace:*",
    "@lualtek/themes": "workspace:*",
    "@lualtek/tokens": "workspace:*",
    "@storybook/addon-actions": "7.6.17",
    "@storybook/addon-essentials": "7.6.17",
    "@storybook/addon-links": "7.6.17",
    "@storybook/addon-styling": "1.3.7",
    "@storybook/addons": "7.6.17",
    "@storybook/react": "7.6.17",
    "@storybook/react-webpack5": "7.6.17",
    "@storybook/theming": "7.6.17",
    "@types/node": "20.11.24",
    "@types/react": "18.2.61",
    "@types/react-dom": "18.2.19",
    "babel-loader": "9.1.3",
    "chromatic": "10.5.0",
    "postcss": "8.4.35",
    "postcss-cli": "11.0.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "storybook": "7.6.17",
    "storybook-addon-themes": "6.1.0",
    "tsconfig": "workspace:*",
    "typed-css-modules": "0.8.1",
    "typedoc": "0.25.3",
    "typedoc-json-parser": "8.2.0",
    "typescript": "5.3.3"
  },
  "dependencies": {
    "@lualtek/icons": "workspace:*",
    "@radix-ui/react-checkbox": "1.0.4",
    "@radix-ui/react-popover": "1.0.7",
    "@radix-ui/react-radio-group": "1.1.3",
    "@radix-ui/react-slider": "1.1.2",
    "@radix-ui/react-switch": "1.0.3",
    "@radix-ui/react-tabs": "1.0.4",
    "@radix-ui/react-toast": "1.1.5",
    "@radix-ui/react-tooltip": "1.0.7",
    "@tanstack/react-table": "8.11.8",
    "clsx": "2.1.0",
    "framer-motion": "10.17.9",
    "react-focus-on": "3.9.2",
    "react-masonry-css": "1.0.16",
    "react-paginate": "8.2.0",
    "react-roving-tabindex": "3.2.0",
    "rooks": "7.14.1",
    "type-fest": "4.11.0"
  }
}
