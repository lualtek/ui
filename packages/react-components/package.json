{
  "name": "@lualtek/react-components",
  "version": "10.3.0",
  "types": "dist/index.d.ts",
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./core.css": "./dist/core.css",
    "./doc/*": "./dist/components/*/*.doc.json"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "scripts": {
    "dev": "run-p storybook watch:csstypes",
    "prebuild": "run-s clean build:csstypes",
    "build": "run-s build:ts build:css copy:fonts build:api",
    "build:css": "cpy '**/*.css' '../dist' --parents --cwd=src && postcss dist/*.css \"dist/**/!(utils)/.css\" --replace",
    "copy:fonts": "cpy 'fonts/*' '../dist' --parents --cwd=src",
    "build:ts": "tsc -p tsconfig.prod.json && tsc-alias",
    "build:api": "typedoc && typedoc-json-parser --json dist/api-temp.json && ts-node ./generate-api-doc",
    "postbuild:api": "rimraf dist/api-temp.json",
    "storybook": "storybook dev --quiet -p 6006",
    "watch:csstypes": "tcm -w -p '**/*.module.css' src",
    "build:csstypes": "tcm -p '**/*.module.css' src",
    "clean": "rimraf dist core core.css"
  },
  "repository": {
    "type": "git",
    "url": "ssh+https://github.com/lualtek/ui.git",
    "directory": "packages/react-components"
  },
  "bugs": {
    "url": "https://github.com/lualtek/ui/issues"
  },
  "homepage": "https://github.com/lualtek/ui",
  "browserslist": [
    "last 1 Chrome versions",
    "last 1 Firefox versions",
    "last 1 Safari versions",
    "last 1 Edge versions"
  ],
  "peerDependencies": {
    "constate": "^3.3.2",
    "react": "^18.2",
    "react-dom": "^18.2"
  },
  "devDependencies": {
    "@babel/core": "7.22.20",
    "@babel/preset-env": "7.22.20",
    "@babel/preset-react": "7.22.15",
    "@babel/preset-typescript": "7.22.15",
    "@lualtek/config": "10.3.0",
    "@storybook/addon-actions": "7.4.2",
    "@storybook/addon-essentials": "7.4.2",
    "@storybook/addon-links": "7.4.2",
    "@storybook/addon-styling": "1.3.7",
    "@storybook/addons": "7.4.2",
    "@storybook/react": "7.4.2",
    "@storybook/react-webpack5": "7.4.2",
    "@storybook/theming": "7.4.2",
    "@types/react": "18.2.22",
    "@types/react-dom": "18.2.7",
    "babel-loader": "9.1.3",
    "postcss": "8.4.30",
    "postcss-cli": "10.1.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "storybook": "7.4.2",
    "storybook-addon-themes": "6.1.0",
    "tsconfig": "*",
    "typed-css-modules": "0.7.2",
    "typedoc": "0.25.1",
    "typedoc-json-parser": "9.0.0",
    "typescript": "5.2.2"
  },
  "dependencies": {
    "@lualtek/icons": "10.3.0",
    "@radix-ui/react-checkbox": "1.0.4",
    "@radix-ui/react-popover": "1.0.6",
    "@radix-ui/react-radio-group": "1.1.3",
    "@radix-ui/react-slider": "1.1.2",
    "@radix-ui/react-switch": "1.0.3",
    "@radix-ui/react-tabs": "1.0.4",
    "@radix-ui/react-toast": "1.1.4",
    "@radix-ui/react-tooltip": "1.0.6",
    "@tanstack/react-table": "8.10.6",
    "clsx": "2.0.0",
    "framer-motion": "10.16.4",
    "react-focus-on": "3.9.1",
    "react-masonry-css": "1.0.16",
    "react-paginate": "8.2.0",
    "react-roving-tabindex": "3.2.0",
    "rooks": "7.14.1",
    "type-fest": "4.3.1"
  }
}
