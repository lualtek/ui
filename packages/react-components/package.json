{
  "name": "@lualtek/react-components",
  "version": "11.16.0",
  "files": [
    "dist"
  ],
  "type": "module",
  "types": "dist/index.d.ts",
  "module": "dist/index.js",
  "main": "dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./core.css": "./dist/core.css",
    "./doc/*": "./dist/components/*/*.doc.json",
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "scripts": {
    "dev": "pnpm run --parallel storybook watch:csstypes",
    "prebuild": "pnpm run clean && pnpm run build:csstypes",
    "build": "pnpm run build:ts && pnpm run build:css && pnpm run copy:fonts && pnpm run build:api",
    "build:css": "cd src && copyfiles \"**/*.css\" \"./../dist\" && cd .. && postcss dist/*.css \"dist/**/!(utils)/.css\" --replace",
    "copy:fonts": "cd src && copyfiles \"./fonts/*\" \"./../dist\" && cd ..",
    "build:ts": "tsc -p tsconfig.prod.json && tsc-alias",
    "build:api": "typedoc && typedoc-json-parser --json dist/api-temp.json && node --loader ts-node/esm ./generate-api-doc.ts",
    "postbuild:api": "rimraf dist/api-temp.json",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "watch:csstypes": "tcm -w -p '**/*.module.css' src",
    "build:csstypes": "tcm -p '**/*.module.css' src",
    "clean": "rimraf dist core core.css",
    "prepack": "node --loader ts-node/esm ./prepack.ts"
  },
  "repository": {
    "type": "git",
    "url": "ssh+https://github.com/lualtek/ui.git",
    "directory": "packages/react-components"
  },
  "bugs": {
    "url": "https://github.com/lualtek/ui/issues"
  },
  "homepage": "https://github.com/lualtek/ui",
  "browserslist": [
    "last 2 Chrome versions",
    "last 2 Firefox versions",
    "last 2 Safari versions",
    "last 2 Edge versions"
  ],
  "peerDependencies": {
    "constate": "^3.3.2",
    "react": "^18.2",
    "react-dom": "^18.2"
  },
  "devDependencies": {
    "@lualtek/config": "workspace:*",
    "@lualtek/themes": "workspace:*",
    "@lualtek/tokens": "workspace:*",
    "@storybook/addon-essentials": "8.0.2",
    "@storybook/addon-interactions": "8.0.2",
    "@storybook/addon-links": "8.0.2",
    "@storybook/addon-onboarding": "8.0.2",
    "@storybook/addon-themes": "8.0.2",
    "@storybook/blocks": "8.0.2",
    "@storybook/manager-api": "8.0.2",
    "@storybook/preview-api": "8.0.2",
    "@storybook/react": "8.0.2",
    "@storybook/react-vite": "8.0.2",
    "@storybook/test": "8.0.2",
    "@storybook/theming": "8.0.2",
    "@types/node": "20.12.7",
    "@types/react": "18.2.78",
    "@types/react-dom": "18.2.25",
    "chromatic": "11.3.0",
    "postcss": "8.4.38",
    "postcss-cli": "11.0.0",
    "postcss-dark-theme-class": "1.2.1",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "storybook": "8.0.2",
    "tsconfig": "workspace:*",
    "typed-css-modules": "0.9.1",
    "typedoc": "0.25.13",
    "typedoc-json-parser": "9.0.1",
    "typescript": "5.4.5"
  },
  "dependencies": {
    "@lualtek/icons": "workspace:*",
    "@radix-ui/react-checkbox": "1.0.4",
    "@radix-ui/react-popover": "1.0.7",
    "@radix-ui/react-radio-group": "1.1.3",
    "@radix-ui/react-slider": "1.1.2",
    "@radix-ui/react-switch": "1.0.3",
    "@radix-ui/react-tabs": "1.0.4",
    "@radix-ui/react-toast": "1.1.5",
    "@radix-ui/react-tooltip": "1.0.7",
    "@tanstack/react-table": "8.16.0",
    "clsx": "2.1.0",
    "framer-motion": "11.0.28",
    "react-focus-on": "3.9.3",
    "react-masonry-css": "1.0.16",
    "react-paginate": "8.2.0",
    "react-roving-tabindex": "3.2.0",
    "rooks": "7.14.1",
    "type-fest": "4.15.0"
  }
}
