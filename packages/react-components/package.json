{
  "name": "@lualtek/react-components",
  "version": "20.6.1",
  "files": [
    "dist"
  ],
  "type": "module",
  "types": "dist/index.d.ts",
  "module": "dist/index.js",
  "main": "dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./core.css": "./dist/core.css",
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "scripts": {
    "dev": "pnpm run --parallel watch:csstypes",
    "prebuild": "pnpm run clean && pnpm run build:csstypes",
    "build": "pnpm run build:ts && pnpm run build:css && pnpm run copy:fonts",
    "build:css": "cd src && copyfiles \"**/*.css\" \"./../dist\" && cd .. && postcss dist/*.css \"dist/**/!(utils)/*.css\" --replace",
    "copy:fonts": "cd src && copyfiles \"./fonts/*\" \"./../dist\" && cd ..",
    "build:ts": "tsc -p tsconfig.prod.json && tsc-alias",
    "watch:csstypes": "tcm -w -p '**/*.module.css' src",
    "build:csstypes": "tcm -p '**/*.module.css' src",
    "clean": "rimraf dist core core.css",
    "prepack": "tsx ./prepack.ts"
  },
  "repository": {
    "type": "git",
    "url": "ssh+https://github.com/lualtek/ui.git",
    "directory": "packages/react-components"
  },
  "bugs": {
    "url": "https://github.com/lualtek/ui/issues"
  },
  "homepage": "https://github.com/lualtek/ui",
  "browserslist": [
    "last 2 Chrome versions",
    "last 2 Firefox versions",
    "last 2 Safari versions",
    "last 2 Edge versions",
    "not dead",
    "not op_mini all"
  ],
  "peerDependencies": {
    "constate": "^3.3.3",
    "react": "^19.1",
    "react-dom": "^19.1"
  },
  "devDependencies": {
    "@lualtek/config": "workspace:*",
    "@lualtek/themes": "workspace:*",
    "@lualtek/tokens": "workspace:*",
    "@types/node": "24.5.2",
    "@types/react": "19.1.13",
    "@types/react-dom": "19.1.9",
    "postcss": "8.5.6",
    "postcss-cli": "11.0.1",
    "react": "19.1",
    "react-dom": "19.1",
    "tsconfig": "workspace:*",
    "typed-css-modules": "0.9.1",
    "typescript": "5.9.2"
  },
  "dependencies": {
    "@lualtek/icons": "workspace:*",
    "@radix-ui/react-popover": "1.1.15",
    "@radix-ui/react-slider": "1.3.6",
    "@radix-ui/react-switch": "1.2.6",
    "@radix-ui/react-tabs": "1.1.13",
    "@radix-ui/react-toast": "1.2.15",
    "@radix-ui/react-tooltip": "1.2.8",
    "@tanstack/react-table": "8.21.3",
    "clsx": "2.1.1",
    "emoji-picker-react": "4.13.3",
    "motion": "12.3.1",
    "react-focus-on": "3.10.0",
    "react-masonry-css": "1.0.16",
    "react-merge-refs": "3.0.2",
    "react-paginate": "8.3.0",
    "react-roving-tabindex": "3.2.0",
    "react-use": "17.6.0",
    "type-fest": "5.2.0",
    "vaul": "1.1.2"
  }
}
