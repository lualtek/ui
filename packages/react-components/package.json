{
  "name": "@lualtek/react-components",
  "version": "4.10.0",
  "types": "dist/index.d.ts",
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./core.css": "./dist/core.css"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "scripts": {
    "dev": "run-p storybook watch:csstypes",
    "prebuild": "run-s clean build:csstypes",
    "build": "run-s build:ts build:css",
    "build:css": "cpy '**/*.css' '../dist' --parents --cwd=src && postcss dist/*.css \"dist/**/!(utils)/!(_mixins).css\" --replace",
    "postbuild:css": "rimraf dist/**/_mixins.css",
    "build:ts": "tsc && tsc-alias",
    "storybook": "storybook dev --quiet -p 6006",
    "watch:csstypes": "tcm -w -p '**/*.module.css' src",
    "build:csstypes": "tcm -p '**/*.module.css' src",
    "clean": "rimraf dist core core.css"
  },
  "repository": {
    "type": "git",
    "url": "ssh+https://github.com/lualtek/ui.git",
    "directory": "packages/react-components"
  },
  "bugs": {
    "url": "https://github.com/lualtek/ui/issues"
  },
  "homepage": "https://github.com/lualtek/ui",
  "browserslist": [
    "last 2 Chrome versions",
    "last 2 Firefox versions",
    "last 2 Safari versions",
    "last 2 Edge versions"
  ],
  "peerDependencies": {
    "constate": "^3.3.2",
    "react": "^18.2",
    "react-dom": "^18.2"
  },
  "devDependencies": {
    "@babel/core": "7.21.4",
    "@babel/preset-env": "7.21.4",
    "@babel/preset-react": "7.18.6",
    "@babel/preset-typescript": "7.21.4",
    "@lualtek/config": "*",
    "@storybook/addon-actions": "7.0.3",
    "@storybook/addon-essentials": "7.0.3",
    "@storybook/addon-links": "7.0.3",
    "@storybook/addon-mdx-gfm": "7.0.3",
    "@storybook/addon-postcss": "2.0.0",
    "@storybook/addons": "7.0.3",
    "@storybook/react": "7.0.3",
    "@storybook/react-webpack5": "7.0.3",
    "@storybook/theming": "7.0.3",
    "@types/react": "18.0.34",
    "@types/react-dom": "18.0.11",
    "babel-loader": "9.1.2",
    "postcss": "8.4.21",
    "postcss-cli": "10.1.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "storybook": "7.0.3",
    "storybook-addon-themes": "6.1.0",
    "storybook-css-modules-preset": "1.1.1",
    "tsconfig": "*",
    "typed-css-modules": "0.7.2",
    "typescript": "4.9.4"
  },
  "dependencies": {
    "@lualtek/icons": "*",
    "@radix-ui/react-checkbox": "1.0.3",
    "@radix-ui/react-popover": "1.0.5",
    "@radix-ui/react-radio-group": "1.1.2",
    "@radix-ui/react-slider": "1.1.1",
    "@radix-ui/react-switch": "1.0.2",
    "@radix-ui/react-tabs": "1.0.3",
    "@radix-ui/react-toast": "1.1.3",
    "@radix-ui/react-tooltip": "1.0.5",
    "@tanstack/react-table": "8.8.5",
    "clsx": "1.2.1",
    "framer-motion": "10.11.5",
    "react-focus-on": "3.8.0",
    "react-masonry-css": "1.0.16",
    "react-paginate": "8.1.5",
    "react-roving-tabindex": "3.2.0",
    "rooks": "7.11.0",
    "type-fest": "3.8.0"
  }
}
