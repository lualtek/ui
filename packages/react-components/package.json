{
  "name": "@lualtek/react-components",
  "version": "0.26.1",
  "types": "dist/index.d.ts",
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./core.css": "./dist/core.css"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "scripts": {
    "dev": "start-storybook --quiet -p 6006",
    "prebuild": "rimraf dist core core.css",
    "build": "run-s build:ts build:css",
    "build:css": "cpy '**/*.css' '../dist' --parents --cwd=src && postcss dist/*.css \"dist/**/!(utils)/!(_mixins).css\" --replace",
    "postbuild:css": "rimraf dist/**/_mixins.css",
    "build:ts": "tsc && tsc-alias",
    "storybook": "start-storybook -p 6006"
  },
  "repository": {
    "type": "git",
    "url": "ssh+https://github.com/lualtek/ui.git",
    "directory": "packages/react-components"
  },
  "bugs": {
    "url": "https://github.com/lualtek/ui/issues"
  },
  "homepage": "https://github.com/lualtek/ui",
  "browserslist": [
    "last 2 Chrome versions",
    "last 2 Firefox versions",
    "last 2 Safari versions",
    "last 2 Edge versions"
  ],
  "peerDependencies": {
    "react": "^17.0",
    "react-dom": "^17.0"
  },
  "devDependencies": {
    "@babel/core": "7.18.9",
    "@babel/preset-typescript": "7.18.6",
    "@lualtek/config": "*",
    "@storybook/addon-actions": "6.5.9",
    "@storybook/addon-essentials": "6.5.9",
    "@storybook/addon-links": "6.5.9",
    "@storybook/addon-postcss": "2.0.0",
    "@storybook/addons": "6.5.9",
    "@storybook/builder-webpack5": "6.5.9",
    "@storybook/manager-webpack5": "6.5.9",
    "@storybook/react": "6.5.9",
    "@storybook/theming": "6.5.9",
    "@types/react": "17.0.38",
    "@types/react-dom": "17.0.11",
    "@types/react-table": "7.7.12",
    "babel-loader": "8.2.5",
    "cpy-cli": "3.1.1",
    "postcss": "8.4.14",
    "postcss-cli": "9.1.0",
    "storybook-addon-themes": "6.1.0",
    "storybook-css-modules-preset": "1.1.1",
    "tsconfig": "*",
