{
  "extends": "tsconfig/react-library.json",
  "compilerOptions": {
    "outDir": "dist",
    "moduleResolution": "bundler",
    "paths": {
      "@/components": ["./src"],
      "@/components/types": ["./src/types"],
      "@/components/utils": ["./src/utils"],
      "@/components/lib": ["./src/lib"],
      "@lualtek/icons/sprite": ["../icons/dist/sprite"],
      "@lualtek/tokens": ["../tokens/platforms/web"],
      "@lualtek/tokens/*": ["../tokens/*"]
    }
  },
  "include": ["src", "types", "generate-api-doc.ts"],
  "exclude": ["dist", "build", "node_modules"]
}
