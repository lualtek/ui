{
  "plugins": [
    "stylelint-design-tokens-plugin"
  ],
  "extends": [
    "stylelint-config-equinusocio"
  ],
  "rules": {
    "designtokens/check": [
      true,
      "./packages/tokens/platforms/web/tokens.json"
    ]
  },
  "ignoreFiles": [
    "!**/*.css",
    "**/*.jsx",
    "**/*.tsx",
    "**/*.ts",
    "node_modules"
  ]
}
