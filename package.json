{
  "name": "@lualtek/ui",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "build:nocache": "turbo run build --force",
    "dev": "turbo run dev",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "lint": "turbo run lint",
    "test": "echo \"Add some test\"",
    "release": "changeset publish",
    "prepare": "husky",
    "change": "changeset",
    "change:enter-next": "./scripts/changeset-next-enter.sh && changeset pre enter next",
    "upgrade-interactive": "npx npm-upgrade-monorepo"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": "eslint",
    "*.css": "stylelint"
  },
  "devDependencies": {
    "@changesets/cli": "2.27.1",
    "@chromatic-com/storybook": "^1",
    "@commitlint/cli": "19.2.2",
    "@commitlint/config-conventional": "19.2.2",
    "@lasalefamine/eslint-config": "3.1.0",
    "@lualtek/config": "workspace:*",
    "@lualtek/themes": "workspace:*",
    "@lualtek/tokens": "workspace:*",
    "@storybook/addon-essentials": "^8.0.9",
    "@storybook/addon-interactions": "^8.0.9",
    "@storybook/addon-links": "^8.0.9",
    "@storybook/addon-onboarding": "^8.0.9",
    "@storybook/addon-themes": "^8.0.9",
    "@storybook/blocks": "^8.0.9",
    "@storybook/manager-api": "^8.0.9",
    "@storybook/preview-api": "^8.0.9",
    "@storybook/react": "^8.0.9",
    "@storybook/react-vite": "^8.0.9",
    "@storybook/test": "^8.0.9",
    "@storybook/theming": "^8.0.9",
    "@types/node": "20.12.7",
    "@typescript-eslint/eslint-plugin": "7.6.0",
    "@typescript-eslint/parser": "7.6.0",
    "copyfiles": "2.4.1",
    "eslint": "8.57.0",
    "eslint-plugin-import": "2.29.1",
    "eslint-plugin-jsx-a11y": "6.8.0",
    "eslint-plugin-react": "7.34.1",
    "eslint-plugin-react-hooks": "4.6.0",
    "eslint-plugin-simple-import-sort": "12.1.0",
    "husky": "9.0.11",
    "lint-staged": "15.2.2",
    "npm-run-all": "4.1.5",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "rimraf": "5.0.5",
    "storybook": "^8.0.9",
    "stylelint": "16.3.1",
    "stylelint-config-equinusocio": "1.11.1",
    "stylelint-design-tokens-plugin": "0.0.14",
    "ts-node": "10.9.2",
    "tsc-alias": "1.8.8",
    "turbo": "1.13.2",
    "typescript": "5.4.5"
  },
  "engines": {
    "pnpm": ">=8.0.0",
    "node": ">=18.0.0"
  }
}
