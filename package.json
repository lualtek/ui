{
  "name": "@lualtek/ui",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.29.3",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "build:nocache": "turbo run build --force",
    "start": "turbo run dev --parallel",
    "dev": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "lint": "turbo run lint",
    "test": "echo \"Add some test\"",
    "release": "changeset publish",
    "prepare": "husky",
    "change": "changeset",
    "change:enter-next": "./scripts/changeset-next-enter.sh && changeset pre enter next",
    "upgrade-interactive": "pnpm dlx npm-upgrade-monorepo"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs}": "eslint",
    "*": "biome lint --no-errors-on-unmatched --files-ignore-unknown=true"
  },
  "browserslist": [
    "last 2 Chrome versions",
    "last 2 Firefox versions",
    "last 2 Safari versions",
    "last 2 Edge versions",
    "not dead",
    "not op_mini all"
  ],
  "devDependencies": {
    "@biomejs/biome": "2.3.15",
    "@changesets/cli": "2.29.8",
    "@commitlint/cli": "20.4.1",
    "@commitlint/config-conventional": "20.4.1",
    "@eslint/compat": "2.0.2",
    "@eslint/eslintrc": "3.3.3",
    "@eslint/js": "9.39.2",
    "@lasalefamine/eslint-config": "6.0.0",
    "@lualtek/biome-config": "1.1.1",
    "@lualtek/config": "workspace:*",
    "@lualtek/themes": "workspace:*",
    "@lualtek/tokens": "workspace:*",
    "@storybook/addon-docs": "10.2.8",
    "@storybook/addon-links": "10.2.8",
    "@storybook/addon-themes": "10.2.8",
    "@storybook/react-vite": "10.2.8",
    "@stylistic/eslint-plugin": "5.8.0",
    "@types/node": "25.2.3",
    "@typescript-eslint/eslint-plugin": "8.55.0",
    "@typescript-eslint/parser": "8.55.0",
    "@vitejs/plugin-react": "5.1.4",
    "copyfiles": "2.4.1",
    "eslint": "9.39.2",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-simple-import-sort": "12.1.1",
    "eslint-plugin-storybook": "10.2.8",
    "husky": "9.1.7",
    "lint-staged": "16.2.7",
    "npm-run-all": "4.1.5",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "rimraf": "6.1.2",
    "storybook": "10.2.8",
    "storybook-addon-tag-badges": "3.0.6",
    "tsc-alias": "1.8.16",
    "tsx": "4.21.0",
    "turbo": "2.8.7",
    "typescript": "5.9.3",
    "vite": "7.3.1",
    "vite-tsconfig-paths": "6.1.1"
  },
  "engines": {
    "pnpm": ">=8.0.0",
    "node": ">=18.0.0"
  }
}
