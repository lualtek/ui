{
  "name": "@lualtek/ui",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@9.9.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "build:nocache": "turbo run build --force",
    "start": "turbo run dev --parallel",
    "dev": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "lint": "turbo run lint",
    "test": "echo \"Add some test\"",
    "release": "changeset publish",
    "prepare": "husky",
    "change": "changeset",
    "change:enter-next": "./scripts/changeset-next-enter.sh && changeset pre enter next",
    "upgrade-interactive": "pnpm dlx npm-upgrade-monorepo"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs}": "eslint",
    "*": "biome lint --no-errors-on-unmatched --files-ignore-unknown=true"
  },
  "browserslist": [
    "last 2 Chrome versions",
    "last 2 Firefox versions",
    "last 2 Safari versions",
    "last 2 Edge versions",
    "not dead",
    "not op_mini all"
  ],
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@changesets/cli": "2.27.10",
    "@commitlint/cli": "19.6.0",
    "@commitlint/config-conventional": "19.6.0",
    "@eslint/compat": "1.2.3",
    "@eslint/eslintrc": "3.2.0",
    "@eslint/js": "9.15.0",
    "@lasalefamine/eslint-config": "5.0.0",
    "@lualtek/biome-config": "1.0.1",
    "@lualtek/config": "workspace:*",
    "@lualtek/themes": "workspace:*",
    "@lualtek/tokens": "workspace:*",
    "@storybook/addon-essentials": "8.4.5",
    "@storybook/addon-interactions": "8.4.5",
    "@storybook/addon-links": "8.4.5",
    "@storybook/addon-onboarding": "8.4.5",
    "@storybook/addon-themes": "8.4.5",
    "@storybook/blocks": "8.4.5",
    "@storybook/manager-api": "8.4.5",
    "@storybook/preview-api": "8.4.5",
    "@storybook/react": "8.4.5",
    "@storybook/react-vite": "8.4.5",
    "@storybook/test": "8.4.5",
    "@storybook/theming": "8.4.5",
    "@types/node": "22.9.1",
    "@typescript-eslint/eslint-plugin": "8.22.0",
    "@typescript-eslint/parser": "8.22.0",
    "copyfiles": "2.4.1",
    "eslint": "9.19.0",
    "eslint-plugin-import": "2.31.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-react": "7.37.4",
    "eslint-plugin-react-hooks": "5.1.0",
    "eslint-plugin-simple-import-sort": "12.1.1",
    "husky": "9.1.7",
    "lint-staged": "15.2.10",
    "npm-run-all": "4.1.5",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "rimraf": "6.0.1",
    "storybook": "8.4.5",
    "storybook-addon-tag-badges": "1.3.1",
    "tsc-alias": "1.8.10",
    "tsx": "4.19.2",
    "turbo": "2.3.3",
    "typescript": "5.6.3"
  },
  "engines": {
    "pnpm": ">=8.0.0",
    "node": ">=18.0.0"
  }
}
