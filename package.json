{
  "name": "@lualtek/ui",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "packageManager": "npm@8.3.1",
  "scripts": {
    "build": "turbo run build",
    "build:nocache": "turbo run build --force",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "test": "echo \"Add some tests\"",
    "release": "changeset publish",
    "prepare": "husky install",
    "change": "changeset",
    "upgrade-interactive": "npx npm-upgrade-monorepo"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": "eslint",
    "*.css": "stylelint"
  },
  "devDependencies": {
    "@changesets/cli": "2.26.2",
    "@commitlint/cli": "17.6.6",
    "@commitlint/config-conventional": "17.6.6",
    "@lasalefamine/eslint-config": "3.0.2",
    "@typescript-eslint/eslint-plugin": "5.61.0",
    "@typescript-eslint/parser": "5.61.0",
    "cpy-cli": "3.1.1",
    "eslint": "8.44.0",
    "eslint-plugin-import": "2.27.5",
    "eslint-plugin-jsx-a11y": "6.7.1",
    "eslint-plugin-react": "7.32.2",
    "eslint-plugin-react-hooks": "4.6.0",
    "eslint-plugin-simple-import-sort": "10.0.0",
    "husky": "8.0.3",
    "lint-staged": "13.2.3",
    "npm-run-all": "4.1.5",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "rimraf": "5.0.1",
    "stylelint": "15.10.1",
    "stylelint-config-equinusocio": "1.7.0",
    "stylelint-config-standard": "34",
    "stylelint-design-tokens-plugin": "0.0.14",
    "ts-node": "10.9.1",
    "tsc-alias": "1.8.7",
    "turbo": "1.10.7",
    "typescript": "4.9.4"
  },
  "engines": {
    "npm": ">=8.0.0",
    "node": ">=14.0.0"
  }
}
