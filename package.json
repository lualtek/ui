{
  "name": "@lualtek/ui",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "build:nocache": "turbo run build --force",
    "start": "turbo run dev --parallel",
    "dev": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "lint": "biome lint --no-errors-on-unmatched --files-ignore-unknown=true",
    "test": "echo \"Add some test\"",
    "release": "changeset publish",
    "prepare": "husky",
    "change": "changeset",
    "change:enter-next": "./scripts/changeset-next-enter.sh && changeset pre enter next",
    "upgrade-interactive": "pnpm dlx npm-upgrade-monorepo"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.5",
    "@changesets/cli": "2.29.8",
    "@commitlint/cli": "20.4.2",
    "@commitlint/config-conventional": "20.4.2",
    "@lualtek/biome-config": "1.1.2",
    "@lualtek/config": "workspace:*",
    "@lualtek/themes": "workspace:*",
    "@lualtek/tokens": "workspace:*",
    "@storybook/addon-docs": "10.2.14",
    "@storybook/addon-links": "10.2.14",
    "@storybook/addon-themes": "10.2.14",
    "@storybook/react-vite": "10.2.14",
    "@types/node": "25.3.3",
    "@vitejs/plugin-react": "5.1.4",
    "copyfiles": "2.4.1",
    "eslint-plugin-storybook": "10.2.14",
    "husky": "9.1.7",
    "lint-staged": "16.3.1",
    "npm-run-all": "4.1.5",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "rimraf": "6.1.3",
    "storybook": "10.2.14",
    "storybook-addon-tag-badges": "3.0.6",
    "tsc-alias": "1.8.16",
    "tsx": "4.21.0",
    "turbo": "2.8.12",
    "typescript": "5.9.3",
    "vite": "7.3.1",
    "vite-tsconfig-paths": "6.1.1"
  },
  "lint-staged": {
    "*": "biome lint --no-errors-on-unmatched --files-ignore-unknown=true"
  },
  "browserslist": [
    "last 2 Chrome versions",
    "last 2 Firefox versions",
    "last 2 Safari versions",
    "last 2 Edge versions",
    "not dead",
    "not op_mini all"
  ],
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@10.30.3"
}
