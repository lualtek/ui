{
  "name": "@lualtek/ui",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "packageManager": "npm@8.3.1",
  "scripts": {
    "build": "turbo run build",
    "build:nocache": "turbo run build --force",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "test": "echo \"Add some tests\"",
    "release": "changeset publish",
    "prepare": "husky install",
    "change": "changeset",
    "upgrade-interactive": "npx npm-upgrade-monorepo"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": "eslint",
    "*.css": "stylelint"
  },
  "devDependencies": {
    "@changesets/cli": "2.24.4",
    "@commitlint/cli": "17.1.2",
    "@commitlint/config-conventional": "17.1.0",
    "@lasalefamine/eslint-config": "2.0.7",
    "@typescript-eslint/eslint-plugin": "5.38.0",
    "@typescript-eslint/parser": "5.38.0",
    "cpy-cli": "3.1.1",
    "eslint": "8.23.1",
    "eslint-plugin-import": "2.26.0",
    "eslint-plugin-jsx-a11y": "6.6.1",
    "eslint-plugin-react": "7.31.8",
    "eslint-plugin-react-hooks": "4.6.0",
    "eslint-plugin-simple-import-sort": "8.0.0",
    "husky": "8.0.1",
    "lint-staged": "13.0.3",
    "npm-run-all": "4.1.5",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "rimraf": "3.0.2",
    "stylelint": "14.12.0",
    "stylelint-config-equinusocio": "1.6.4",
    "stylelint-config-standard": "27",
    "stylelint-design-tokens-plugin": "0.0.14",
    "tsc-alias": "1.7.0",
    "turbo": "1.4.7",
    "typescript": "4.7.4"
  },
  "engines": {
    "npm": ">=8.0.0",
    "node": ">=14.0.0"
  },
  "dependencies": {
    "constate": "3.3.2"
  }
}
