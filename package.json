{
  "name": "@lualtek/ui",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "packageManager": "pnpm@8.15.5",
  "scripts": {
    "build": "turbo run build",
    "build:nocache": "turbo run build --force",
    "start": "turbo run dev --parallel",
    "dev": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "lint": "turbo run lint",
    "test": "echo \"Add some test\"",
    "release": "changeset publish",
    "prepare": "husky",
    "change": "changeset",
    "change:enter-next": "./scripts/changeset-next-enter.sh && changeset pre enter next",
    "upgrade-interactive": "pnpm dlx npm-upgrade-monorepo"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": "eslint",
    "*.css": "stylelint"
  },
  "devDependencies": {
    "@changesets/cli": "2.27.7",
    "@commitlint/cli": "19.3.0",
    "@commitlint/config-conventional": "19.2.2",
    "@lasalefamine/eslint-config": "3.1.0",
    "@lualtek/config": "workspace:*",
    "@lualtek/themes": "workspace:*",
    "@lualtek/tokens": "workspace:*",
    "@storybook/addon-essentials": "8.2.1",
    "@storybook/addon-interactions": "8.2.1",
    "@storybook/addon-links": "8.2.1",
    "@storybook/addon-onboarding": "8.2.1",
    "@storybook/addon-themes": "8.2.1",
    "@storybook/blocks": "8.2.1",
    "@storybook/manager-api": "8.2.1",
    "@storybook/preview-api": "8.2.1",
    "@storybook/react": "8.2.1",
    "@storybook/react-vite": "8.2.1",
    "@storybook/test": "8.2.1",
    "@storybook/theming": "8.2.1",
    "@types/node": "20.14.10",
    "@typescript-eslint/eslint-plugin": "7.16.0",
    "@typescript-eslint/parser": "7.16.0",
    "copyfiles": "2.4.1",
    "eslint": "8.57.0",
    "eslint-plugin-import": "2.29.1",
    "eslint-plugin-jsx-a11y": "6.9.0",
    "eslint-plugin-react": "7.34.3",
    "eslint-plugin-react-hooks": "4.6.2",
    "eslint-plugin-simple-import-sort": "12.1.1",
    "husky": "9.0.11",
    "lint-staged": "15.2.7",
    "npm-run-all": "4.1.5",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "rimraf": "6.0.1",
    "storybook": "8.2.1",
    "stylelint": "16.6.1",
    "stylelint-config-equinusocio": "1.11.1",
    "stylelint-design-tokens-plugin": "0.0.14",
    "ts-node": "10.9.2",
    "tsc-alias": "1.8.10",
    "turbo": "2.0.6",
    "typescript": "5.5.3"
  },
  "engines": {
    "pnpm": ">=8.0.0",
    "node": ">=18.0.0"
  }
}
