{
  "name": "@lualtek/ui",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "packageManager": "npm@8.3.1",
  "scripts": {
    "build": "turbo run build",
    "build:nocache": "turbo run build --force",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "chromatic": "turbo run test",
    "build-storybook": "npm run-script build-storybook --workspace=packages/react-components",
    "release": "changeset publish",
    "prepare": "husky install",
    "change": "changeset",
    "upgrade-interactive": "npx npm-upgrade-monorepo"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": "eslint",
    "*.css": "stylelint"
  },
  "devDependencies": {
    "@changesets/cli": "2.27.1",
    "@commitlint/cli": "18.4.4",
    "@commitlint/config-conventional": "18.4.4",
    "@lasalefamine/eslint-config": "3.1.0",
    "@typescript-eslint/eslint-plugin": "6.18.0",
    "@typescript-eslint/parser": "6.18.0",
    "cpy-cli": "3.1.1",
    "eslint": "8.56.0",
    "eslint-plugin-import": "2.29.1",
    "eslint-plugin-jsx-a11y": "6.8.0",
    "eslint-plugin-react": "7.33.2",
    "eslint-plugin-react-hooks": "4.6.0",
    "eslint-plugin-simple-import-sort": "10.0.0",
    "husky": "8.0.3",
    "lint-staged": "15.2.0",
    "npm-run-all": "4.1.5",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "rimraf": "5.0.5",
    "stylelint": "15.11.0",
    "stylelint-config-equinusocio": "1.8.0",
    "stylelint-design-tokens-plugin": "0.0.14",
    "ts-node": "10.9.2",
    "tsc-alias": "1.8.8",
    "turbo": "1.11.3",
    "typescript": "5.3.3"
  },
  "engines": {
    "npm": ">=8.0.0",
    "node": ">=14.0.0"
  }
}
