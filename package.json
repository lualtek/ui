{
  "name": "@lualtek/ui",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "build:nocache": "turbo run build --force",
    "start": "turbo run dev --parallel",
    "dev": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "lint": "oxlint .",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "test": "echo \"Add some test\"",
    "release": "changeset publish",
    "prepare": "husky",
    "change": "changeset",
    "change:enter-next": "./scripts/changeset-next-enter.sh && changeset pre enter next",
    "upgrade-interactive": "pnpm dlx npm-upgrade-monorepo"
  },
  "devDependencies": {
    "@changesets/cli": "2.29.8",
    "@commitlint/cli": "20.4.1",
    "@commitlint/config-conventional": "20.4.1",
    "@lualtek/config": "workspace:*",
    "@lualtek/themes": "workspace:*",
    "@lualtek/tokens": "workspace:*",
    "@storybook/addon-docs": "10.2.8",
    "@storybook/addon-links": "10.2.8",
    "@storybook/addon-themes": "10.2.8",
    "@storybook/react-vite": "10.2.8",
    "@types/node": "25.2.3",
    "@vitejs/plugin-react": "5.1.4",
    "copyfiles": "2.4.1",
    "husky": "9.1.7",
    "lint-staged": "16.2.7",
    "npm-run-all": "4.1.5",
    "oxfmt": "0.35.0",
    "oxlint": "1.50.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "rimraf": "6.1.2",
    "storybook": "10.2.8",
    "storybook-addon-tag-badges": "3.0.6",
    "tsc-alias": "1.8.16",
    "tsx": "4.21.0",
    "turbo": "2.8.12",
    "typescript": "5.9.3",
    "vite": "7.3.1",
    "vite-tsconfig-paths": "6.1.1"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs}": "oxlint --fix",
    "*": "oxfmt --no-error-on-unmatched-pattern"
  },
  "browserslist": [
    "last 2 Chrome versions",
    "last 2 Firefox versions",
    "last 2 Safari versions",
    "last 2 Edge versions",
    "not dead",
    "not op_mini all"
  ],
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@10.29.3"
}
